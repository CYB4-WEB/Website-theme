# =============================================================================
# Project Alpha - Security Rules
# =============================================================================
# Place this file in the theme directory: wp-content/themes/starter-theme/
# =============================================================================

# -----------------------------------------------------------------------------
# Block access to environment files
# -----------------------------------------------------------------------------
<FilesMatch "^\.env(\..+)?$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# -----------------------------------------------------------------------------
# Block direct PHP execution in inc/ directory
# -----------------------------------------------------------------------------
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Deny direct access to PHP files in inc/ directory
    RewriteRule ^inc/(.+)\.php$ - [F,L,NC]

    # Deny direct access to PHP files in sample-data/ directory
    RewriteRule ^sample-data/(.*)$ - [F,L,NC]

    # Deny direct access to PHP files in languages/ directory
    RewriteRule ^languages/(.*)$ - [F,L,NC]
</IfModule>

# -----------------------------------------------------------------------------
# Block access to sensitive file types
# -----------------------------------------------------------------------------
<FilesMatch "\.(log|sql|sqlite|bak|old|orig|save|swp|swo|tmp|temp|dist|config|ini|sh|bash|zsh|env|env\..*)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# Block access to common backup / sensitive files by name
<FilesMatch "(^#.*#|~$|\.bak$|\.orig$|wp-config\.php\.bak|readme\.html|license\.txt)">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# -----------------------------------------------------------------------------
# Disable directory browsing
# -----------------------------------------------------------------------------
Options -Indexes

# -----------------------------------------------------------------------------
# Block access to hidden files and directories (dot-files)
# -----------------------------------------------------------------------------
<IfModule mod_rewrite.c>
    RewriteEngine On
    # Block access to hidden files (except .well-known for SSL validation)
    RewriteCond %{REQUEST_URI} "!(^|/)\.well-known/([^./]+./)+" [NC]
    RewriteRule "(^|/)\." - [F,L]
</IfModule>

# -----------------------------------------------------------------------------
# Security Headers
# -----------------------------------------------------------------------------
<IfModule mod_headers.c>
    # Prevent MIME type sniffing
    Header set X-Content-Type-Options "nosniff"

    # Enable XSS protection in older browsers
    Header set X-XSS-Protection "1; mode=block"

    # Prevent clickjacking by disallowing framing
    Header set X-Frame-Options "SAMEORIGIN"

    # Enforce HTTPS via Strict Transport Security (1 year)
    Header set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

    # Referrer policy - send origin only on cross-origin requests
    Header set Referrer-Policy "strict-origin-when-cross-origin"

    # Permissions policy - restrict access to sensitive browser features
    Header set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"

    # Remove server signature / powered-by headers where possible
    Header unset X-Powered-By
    Header unset Server
</IfModule>

# -----------------------------------------------------------------------------
# Prevent PHP file uploads from being executed in uploads
# -----------------------------------------------------------------------------
<IfModule mod_rewrite.c>
    RewriteRule ^uploads/(.+)\.php$ - [F,L,NC]
</IfModule>
