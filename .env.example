# =============================================================================
# Project Alpha - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Encryption
# -----------------------------------------------------------------------------
# 256-bit encryption key for securing sensitive data (tokens, user secrets).
# Generate with: openssl rand -hex 32
STARTER_ENCRYPTION_KEY=your-256-bit-key-here

# -----------------------------------------------------------------------------
# S3-Compatible Object Storage
# -----------------------------------------------------------------------------
# Used for manga/chapter image uploads and media offloading.
# Compatible with AWS S3, DigitalOcean Spaces, MinIO, Backblaze B2, etc.

# Access key ID for your S3-compatible service
STARTER_S3_KEY=your-s3-access-key

# Secret access key for your S3-compatible service
STARTER_S3_SECRET=your-s3-secret-key

# Bucket name where uploads will be stored
STARTER_S3_BUCKET=your-bucket-name

# AWS region or equivalent (e.g., us-east-1, nyc3 for DigitalOcean)
STARTER_S3_REGION=us-east-1

# S3 endpoint URL (leave blank for AWS, set for other providers)
# Examples:
#   DigitalOcean Spaces: https://nyc3.digitaloceanspaces.com
#   MinIO:               https://minio.example.com
#   Backblaze B2:        https://s3.us-west-002.backblazeb2.com
STARTER_S3_ENDPOINT=

# -----------------------------------------------------------------------------
# FTP / SFTP Storage (Alternative to S3)
# -----------------------------------------------------------------------------
# Used when S3 is not available. Uploads chapter images via FTP/SFTP.

# FTP server hostname or IP address
STARTER_FTP_HOST=ftp.example.com

# FTP username
STARTER_FTP_USER=your-ftp-username

# FTP password
STARTER_FTP_PASS=your-ftp-password

# FTP port (default: 21 for FTP, 22 for SFTP)
STARTER_FTP_PORT=21

# Remote path where files will be uploaded (relative to FTP root)
STARTER_FTP_PATH=/public_html/uploads/manga

# Enable SSL/TLS for FTP connections (true/false)
STARTER_FTP_SSL=true

# Connection type: ftp or sftp
STARTER_FTP_TYPE=ftp

# Public URL prefix that maps to the FTP upload path
# This is the URL visitors use to access uploaded files
STARTER_FTP_PUBLIC_URL=https://cdn.example.com/uploads/manga

# -----------------------------------------------------------------------------
# Imgur Integration
# -----------------------------------------------------------------------------
# Fallback image host. Used for user avatars or temporary uploads.
# Register an application at https://api.imgur.com/oauth2/addclient

# Imgur API client ID
STARTER_IMGUR_CLIENT_ID=your-imgur-client-id

# -----------------------------------------------------------------------------
# Google reCAPTCHA v2/v3
# -----------------------------------------------------------------------------
# Protects login, registration, and upload forms from bots.
# Get keys at https://www.google.com/recaptcha/admin

# reCAPTCHA site key (used in frontend)
STARTER_RECAPTCHA_SITE_KEY=your-recaptcha-site-key

# reCAPTCHA secret key (used in backend verification)
STARTER_RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key

# -----------------------------------------------------------------------------
# Debug Mode
# -----------------------------------------------------------------------------
# When true, enables verbose logging, disables caching, and shows debug info
# in the admin bar. NEVER enable on production sites.
STARTER_DEBUG=false
