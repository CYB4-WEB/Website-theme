# =============================================================================
# Project Alpha - Git Ignore
# =============================================================================

# Environment files (keep .env.example, ignore actual .env)
.env
.env.local
.env.production
.env.staging

# Dependencies
node_modules/
vendor/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini

# Editor / IDE files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~

# Build artifacts
dist/
build/

# Uploaded files (user content)
uploads/
!uploads/.gitkeep

# Composer (vendor is generated, but lock file is tracked)
vendor/

# Compiled CSS/JS maps (optional, uncomment if not needed)
# *.map
